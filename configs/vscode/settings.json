				},
				{
					"scope": "meta.brace.square.js",
					"settings": { "foreground": "#89ddff" }
				},
				{
					"scope": "meta.object-literal.key.js",
					"settings": { "foreground": "#89ddff" }
				}
			]
		},
		"[Material Theme Darker]": {
			"textMateRules": [
				{
					"scope": "meta.brace.round.js",
					"settings": { "foreground": "#89ddff" }
				},
				{
					"scope": "meta.brace.square.js",
					"settings": { "foreground": "#89ddff" }
				},
				{
					"scope": "meta.object-literal.key.js",
