[global]
    ### Display ###
    monitor = 0
    follow = none

    width = 350
    height = 300
    origin = top-right
    offset = 20x20

    progress_bar = true
    progress_bar_height = 6
    progress_bar_frame_width = 0
    progress_bar_min_width = 150
    progress_bar_max_width = 320
    progress_bar_corner_radius = 3

    icon_corner_radius = 0
    indicate_hidden = yes
    transparency = 10
    
    separator_height = 2
    padding = 20
    horizontal_padding = 20
    text_icon_padding = 16

    frame_width = 1
    frame_color = "#131313"
    gap_size = 16
    separator_color = frame
    sort = yes
    idle_threshold = 120

    ### Text ###
    font = "system-ui 11"
    line_height = 3
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    word_wrap = yes
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes

    ### Icons ###
    icon_position = left
    min_icon_size = 32
    max_icon_size = 64

    ### History ###
    history_length = 20

    ### Misc/Advanced ###
    dmenu = /usr/bin/anyrun
    browser = /usr/bin/xdg-open
    always_run_script = true
    title = Dunst
    class = Dunst

    corner_radius = 16
    ignore_dbusclose = false

    ### Mouse ###
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#191919"
    foreground = "#c6c6c6"
    timeout = 10

[urgency_normal]
    background = "#191919"
    foreground = "#c6c6c6"
    highlight = "#82aaff"
    timeout = 10

[urgency_critical]
    background = "#191919"
    foreground = "#f07178"
    frame_color = "#f07178"
    timeout = 0
